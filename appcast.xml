            <title>1.3.10</title>
            <pubDate>Fri, 10 Jul 2026 01:50:23 +0800</pubDate>
            <link>https://github.com/junchan0412/SurgeRelay-macOS/releases/tag/v1.3.10</link>
            <sparkle:version>59</sparkle:version>
