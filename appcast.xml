            <pubDate>Sat, 04 Jul 2026 21:41:31 +0800</pubDate>
            <link>https://github.com/junchan0412/SurgeRelay-macOS/releases/tag/v1.3.7</link>
            <sparkle:version>56</sparkle:version>
